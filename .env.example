# ── Local dev ─────────────────────────────────────────────
# Copy to .env and fill in values

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Next.js (local dev — Docker uses http://api:5000 via build arg)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Production ────────────────────────────────────────────
# Fly.io (apps/api): set secrets via CLI:
#   fly secrets set AzureOpenAI__Endpoint="..." AzureOpenAI__ApiKey="..." -a neuralcopy-api
#
# Vercel (apps/web): set in dashboard or via CLI:
#   vercel env add NEXT_PUBLIC_API_URL   → https://neuralcopy-api.fly.dev
